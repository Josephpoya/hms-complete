# =============================================================================
# HMS Docker Environment Variables
# Copy to .env.production and fill in real values before running docker compose.
# NEVER commit .env.production to version control.
# =============================================================================

# ─── Database ─────────────────────────────────────────────────────────────────
DB_NAME=hms_db
DB_USER=hms_user
DB_PASSWORD=STRONG_DATABASE_PASSWORD_CHANGE_ME

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=STRONG_REDIS_PASSWORD_CHANGE_ME
REDIS_MAXMEMORY=512mb

# ─── Django ───────────────────────────────────────────────────────────────────
SECRET_KEY=GENERATE_WITH_python3_-c_"from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DEBUG=False
DJANGO_SETTINGS_MODULE=config.settings.production
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
CORS_ALLOWED_ORIGINS=https://yourdomain.com

# ─── AWS S3 ───────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=hms-documents-production
AWS_S3_REGION_NAME=af-south-1

# ─── SMS (Africa's Talking) ───────────────────────────────────────────────────
SMS_PROVIDER=africastalking           # or: console (dev), twilio
AT_API_KEY=your-africastalking-api-key
AT_USERNAME=your-at-username          # 'sandbox' for testing
AT_SENDER_ID=HMS                      # Registered shortcode/sender ID
AT_ENVIRONMENT=production             # 'sandbox' or 'production'
HMS_PHARMACY_MANAGER_PHONE=+256700000000

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.yourmailprovider.com
EMAIL_PORT=587
EMAIL_HOST_USER=noreply@yourdomain.com
EMAIL_HOST_PASSWORD=

# ─── Sentry ───────────────────────────────────────────────────────────────────
SENTRY_DSN=

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ─── Gunicorn tuning ──────────────────────────────────────────────────────────
GUNICORN_WORKERS=4
GUNICORN_THREADS=2

# ─── Caching ──────────────────────────────────────────────────────────────────
HMS_CACHE_VERSION=v1

# ─── Application constants ────────────────────────────────────────────────────
HMS_MRN_PREFIX=MRN
HMS_INVOICE_PREFIX=INV
HMS_MAX_LOGIN_ATTEMPTS=5
HMS_ACCOUNT_LOCKOUT_MINUTES=30
HMS_PHARMACY_MANAGER_PHONE=+256700000000
LOG_DIR=/var/log/hms
