# -----------------------------------------------------------------
# HMS Environment Variables — copy to .env and fill in real values
# NEVER commit .env to version control
# -----------------------------------------------------------------

# Django
SECRET_KEY=replace-with-a-long-random-string-at-least-50-chars
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
DJANGO_SETTINGS_MODULE=config.settings.production

# Database
DATABASE_URL=postgres://hms_user:strongpassword@localhost:5432/hms_db

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# AWS S3 (document storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=hms-documents
AWS_S3_REGION_NAME=af-south-1

# Sentry (error tracking)
SENTRY_DSN=

# Email
EMAIL_HOST=smtp.yourmailprovider.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@yourhospital.com

# CORS
CORS_ALLOWED_ORIGINS=https://yourdomain.com

# Security
FIELD_ENCRYPTION_KEY=replace-with-32-byte-fernet-key
